{
  "name": "danlog",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "fmt": "oxfmt --check src",
    "fmt:fix": "oxfmt src"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.1",
    "@astrojs/react": "^5.0.6",
    "@astrojs/rss": "^4.0.18",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.4.2",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "nano-staged": "^1.0.2",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "rehype-pretty-code": "^0.14.3",
    "shiki": "^4.1.0",
    "simple-git-hooks": "^2.13.1"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx nano-staged"
  },
  "nano-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "*.{json,md,mdx,css,html}": "oxfmt"
  },
  "engines": {
    "node": ">=24.16.0"
  }
}
