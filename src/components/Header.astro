---
const navItems = [
  { label: "홈", href: "/" },
  { label: "블로그", href: "/blog" },
  { label: "스토어", href: "/store" },
  { label: "프로필", href: "/profile" },
];

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname === href || pathname.startsWith(href + "/");
---

<header
  class="sticky top-0 z-30 h-16 border-b border-hairline bg-canvas/90 backdrop-blur-sm"
>
  <div class="container-page flex h-16 items-center justify-between gap-4">
    <!-- Left: wordmark -->
    <a href="/" class="flex items-center" aria-label="단로그 홈">
      <span class="text-[1.25rem] font-medium tracking-tight text-primary-text">단로그</span>
    </a>

    <!-- Center: primary nav (desktop) -->
    <nav class="absolute left-1/2 hidden -translate-x-1/2 md:flex md:items-center md:gap-1">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? "page" : undefined}
            class:list={[
              "nav-link-type rounded-md px-3 py-2 transition-colors hover:bg-surface-strong",
              isActive(item.href) ? "text-ink" : "text-muted",
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <!-- Right: actions -->
    <div class="flex items-center gap-1">
      <!-- Search trigger: input-style bar on desktop, icon on mobile.
           Both dispatch to the single SearchProvider via [data-search-open]. -->
      <button
        type="button"
        data-search-open
        aria-label="검색 (⌘K)"
        class="hidden h-9 w-56 items-center gap-2 rounded-md border border-hairline bg-canvas-soft pr-2 pl-3 text-muted transition-colors hover:border-hairline-strong sm:inline-flex"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.6"></circle>
          <path d="m20 20-3.5-3.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
        </svg>
        <span class="caption flex-1 text-left">글 검색</span>
        <kbd
          class="code-type rounded border border-hairline-strong bg-surface-card px-1.5 py-0.5 text-[0.6875rem] text-muted"
          >⌘K</kbd
        >
      </button>
      <button
        type="button"
        data-search-open
        aria-label="검색"
        class="grid h-9 w-9 place-items-center rounded-md text-ink transition-colors hover:bg-surface-strong sm:hidden"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.6"></circle>
          <path d="m20 20-3.5-3.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
        </svg>
      </button>
      <a
        href="/feed"
        aria-label="Bluesky 피드"
        class="grid h-9 w-9 place-items-center rounded-md text-ink transition-colors hover:bg-surface-strong"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.479 0-.688-.139-1.86-.902-2.203-.659-.299-1.664-.621-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8Z"
          ></path>
        </svg>
      </a>
      <a
        href="/rss.xml"
        aria-label="RSS 피드"
        class="grid h-9 w-9 place-items-center rounded-md text-ink transition-colors hover:bg-surface-strong"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 11a9 9 0 0 1 9 9M4 4a16 16 0 0 1 16 16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
          <circle cx="5" cy="19" r="1.6" fill="currentColor"></circle>
        </svg>
      </a>
      <!-- Theme toggle (vanilla). Icon swap is pure CSS off html[data-theme];
           the pre-paint script in Layout.astro sets the initial theme. -->
      <button
        id="theme-toggle"
        type="button"
        aria-label="테마 전환"
        class="grid h-9 w-9 place-items-center rounded-md text-ink transition-colors hover:bg-surface-strong"
      >
        <svg
          class="theme-icon-moon"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        <svg
          class="theme-icon-sun"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.6"></circle>
          <path
            d="M12 2v2m0 16v2M4.22 4.22l1.42 1.42m12.72 12.72 1.42 1.42M2 12h2m16 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"></path>
        </svg>
      </button>

      <!-- Mobile nav (vanilla). Panel + icon visibility driven off the button's
           aria-expanded; the script just flips that flag. -->
      <div class="md:hidden">
        <button
          id="mobile-nav-toggle"
          type="button"
          aria-label="메뉴 열기"
          aria-expanded="false"
          aria-controls="mobile-nav-panel"
          class="grid h-9 w-9 place-items-center rounded-md text-ink transition-colors hover:bg-surface-strong"
        >
          <svg
            class="icon-menu"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M3 6h18M3 12h18M3 18h18"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"></path>
          </svg>
          <svg
            class="icon-close"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M6 6l12 12M18 6 6 18"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"></path>
          </svg>
        </button>

        <div
          id="mobile-nav-panel"
          hidden
          class="fixed inset-x-0 top-16 z-40 border-b border-hairline bg-canvas"
        >
          <nav class="container-page flex flex-col py-4">
            {
              navItems.map((item) => (
                <a
                  href={item.href}
                  class:list={[
                    "nav-link-type rounded-md px-3 py-3 transition-colors hover:bg-surface-strong",
                    isActive(item.href) ? "text-ink" : "text-muted",
                  ]}
                >
                  {item.label}
                </a>
              ))
            }
          </nav>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  // Delegated handlers bound once on document; survive ClientRouter swaps.
  function toggleTheme() {
    const current = document.documentElement.dataset.theme === "dark" ? "dark" : "light";
    const next = current === "dark" ? "light" : "dark";
    document.documentElement.dataset.theme = next;
    try {
      localStorage.setItem("danlog-theme", next);
    } catch {
      /* storage unavailable — fine */
    }
  }

  function setMobileNav(open: boolean) {
    const btn = document.getElementById("mobile-nav-toggle");
    const panel = document.getElementById("mobile-nav-panel");
    if (!btn || !panel) return;
    btn.setAttribute("aria-expanded", String(open));
    btn.setAttribute("aria-label", open ? "메뉴 닫기" : "메뉴 열기");
    panel.hidden = !open;
    document.body.style.overflow = open ? "hidden" : "";
  }

  document.addEventListener("click", (e) => {
    const target = e.target as Element | null;
    if (target?.closest("#theme-toggle")) {
      toggleTheme();
      return;
    }
    const navToggle = target?.closest("#mobile-nav-toggle");
    if (navToggle) {
      const open = navToggle.getAttribute("aria-expanded") === "true";
      setMobileNav(!open);
      return;
    }
    // A click inside the open panel (e.g. a nav link) closes it.
    if (target?.closest("#mobile-nav-panel")) setMobileNav(false);
  });

  // Reset any scroll-lock when navigating between pages.
  document.addEventListener("astro:after-swap", () => {
    document.body.style.overflow = "";
  });
</script>
