---
const year = new Date().getFullYear();

const columns = [
  {
    title: "둘러보기",
    links: [
      { label: "홈", href: "/" },
      { label: "블로그", href: "/blog" },
      { label: "스토어", href: "/store" },
      { label: "프로필", href: "/profile" },
    ],
  },
  {
    title: "구독",
    links: [{ label: "RSS", href: "/rss.xml" }],
  },
];
---

<footer class="mt-section border-t border-hairline bg-canvas">
  <div class="container-page flex flex-col gap-10 py-16 md:flex-row md:justify-between">
    <div class="max-w-xs">
      <span class="text-[1.25rem] font-medium tracking-tight text-primary-text">단로그</span>
      <p class="body-sm mt-3 text-body">
        개발과 일상의 기록을 담는 개인 블로그.
      </p>
    </div>

    <div class="flex gap-16">
      {
        columns.map((col) => (
          <nav class="flex flex-col gap-3">
            <span class="caption-uppercase text-muted">{col.title}</span>
            {col.links.map((link) => (
              <a href={link.href} class="body-sm text-body transition-colors hover:text-ink">
                {link.label}
              </a>
            ))}
          </nav>
        ))
      }
    </div>
  </div>

  <div class="border-t border-hairline-soft">
    <div class="container-page py-6">
      <p class="caption text-muted">© {year} 단로그. All rights reserved.</p>
    </div>
  </div>
</footer>
