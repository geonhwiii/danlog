---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { contactEmail, linkedInUrl, skills, testimonials, topics } from "@shared/constants";
import { escapeHtml, highlightBody, toYmd } from "@lib/markdown";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

const fmt = (d: Date) =>
  new Intl.DateTimeFormat("en-US", { year: "numeric", month: "short", day: "numeric" })
    .format(d)
    .toUpperCase();

const editorPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const editorFiles = editorPosts.map((post) => {
  const tags = post.data.tags.length ? post.data.tags.join(", ") : "post";
  const frontmatter =
    `<span class="text-muted">---</span>\n` +
    `title: <span class="text-success">"${escapeHtml(post.data.title)}"</span>\n` +
    `date: <span class="text-success">${toYmd(post.data.date)}</span>\n` +
    `tags: [<span class="text-success">${escapeHtml(tags)}</span>]\n` +
    `<span class="text-muted">---</span>`;
  return {
    id: post.id,
    name: `${post.id}.md`,
    href: `/blog/${post.id}`,
    // Frontmatter renders statically; the body is what types in (after the
    // closing `---`), so we keep the two halves separate.
    frontmatterHtml: `${frontmatter}\n\n`,
    bodyHtml: highlightBody((post as { body?: string }).body ?? ""),
  };
});
---

<Layout>
  <!-- Hero + IDE mockup share a faint dotted backdrop (fades out at the bottom). -->
  <div class="hero-dots relative">
  <!-- ───────────────────────── Hero ───────────────────────── -->
  <section class="container-page pt-section pb-16 text-center md:pb-20">
    <h1 class="display-hero mx-auto mt-8 max-w-4xl text-balance">
      천천히, 꾸준히<br class="hidden sm:block" /> 기록하는 개발 블로그
    </h1>
    <p class="body-md mx-auto mt-6 max-w-xl text-balance text-body">
      개발과 관련된 코드, 생각 등의 기록을 공유하는 개인 블로그입니다.
    </p>

    <div class="mt-9 flex justify-center">
      <button
        type="button"
        data-search-open
        aria-label="검색 (⌘K)"
        class="inline-flex h-13 w-full max-w-md items-center gap-3 rounded-lg border border-hairline-strong bg-surface-card px-4 text-muted transition-colors hover:border-ink"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.6"></circle>
          <path d="m20 20-3.5-3.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
        </svg>
        <span class="body-md flex-1 text-left">글 검색…</span>
        <kbd
          class="code-type rounded border border-hairline px-1.5 py-1 text-[0.75rem] text-muted-soft"
          >⌘K</kbd
        >
      </button>
    </div>
  </section>

  <!-- IDE mockup showpiece — the one "elevated" element (DESIGN.md). -->
  <section class="container-page pb-20">
    <div
      id="hero-editor"
      class="mx-auto max-w-5xl overflow-hidden rounded-xl border border-hairline bg-surface-card"
    >
      <!-- window chrome -->
      <div class="flex items-center gap-2 border-b border-hairline px-4 py-3">
        <span class="h-3 w-3 rounded-full bg-surface-strong"></span>
        <span class="h-3 w-3 rounded-full bg-surface-strong"></span>
        <span class="h-3 w-3 rounded-full bg-surface-strong"></span>
        <span data-file-name class="code-type ml-3 truncate text-muted">단로그 — {editorFiles[0]?.name}</span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-[240px_1fr]">
        <!-- explorer: latest blog posts as real, clickable files -->
        <aside class="border-b border-hairline bg-canvas-soft p-4 md:border-r md:border-b-0">
          <p class="caption-uppercase text-muted">Explorer</p>
          <p class="code-type mt-3 text-ink">📂 blog</p>
          <ul class="mt-1.5 space-y-0.5">
            {
              editorFiles.map((f, i) => (
                <li>
                  <button
                    type="button"
                    data-file-btn={f.id}
                    data-file-name={f.name}
                    data-active={i === 0 ? "" : undefined}
                    title={f.name}
                    class="code-type block w-full truncate rounded-sm px-2 py-1 text-left text-body transition-colors hover:text-ink"
                  >
                    {f.name}
                  </button>
                </li>
              ))
            }
          </ul>
        </aside>

        <!-- editor: shows the selected post's markdown -->
        <div class="bg-canvas-soft p-5 md:p-6">
          {
            editorFiles.map((f, i) => (
              <div data-file-pane={f.id} hidden={i !== 0}>
                <pre class="code-type min-h-[240px] whitespace-pre-wrap wrap-break-word text-body"><code><Fragment set:html={f.frontmatterHtml} /><span data-typing-body set:html={f.bodyHtml} /></code></pre>
                <div class="mt-5 border-t border-hairline pt-4">
                  <a
                    href={f.href}
                    class="text-[0.8125rem] font-medium text-primary transition-colors hover:text-primary-active"
                  >
                    이 글 전체 보기 →
                  </a>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Quiet topics strip (Cursor's logo wall, blog-dialect). -->
    <div class="mx-auto mt-12 max-w-5xl">
      <p class="caption-uppercase text-center text-muted">자주 다루는 주제</p>
      <div class="mt-4 flex flex-wrap items-center justify-center gap-x-8 gap-y-3">
        {
          topics.map((t) => (
            <span class="code-type text-muted-soft transition-colors hover:text-ink">{t}</span>
          ))
        }
      </div>
    </div>
  </section>
  </div>

  <!-- ──────────────── Colleague testimonials ──────────────── -->
  <section class="container-page pb-section">
    <h2 class="display-lg mx-auto max-w-3xl text-balance text-center">
      함께 일한 동료들이 전하는 이야기.
    </h2>

    <div class="relative mt-14">
      <div class="gap-4 [column-fill:balance] sm:columns-2 lg:columns-3">
        {
          testimonials.map((t) => (
            <figure class="mb-4 break-inside-avoid rounded-lg border border-hairline bg-surface-card p-6">
              <figcaption class="flex items-center gap-3">
                <span class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-surface-strong text-[0.875rem] font-medium text-muted">
                  {t.name.slice(0, 1)}
                </span>
                <span class="flex flex-col">
                  <span class="title-sm">{t.name}</span>
                  <span class="caption text-muted">{t.role}</span>
                </span>
              </figcaption>
              <blockquote class="body-md mt-5 text-balance text-ink">“{t.quote}”</blockquote>
            </figure>
          ))
        }
      </div>

      <!-- Bottom fade — cards dissolve into the page background. -->
      <div
        class="pointer-events-none absolute inset-x-0 bottom-0 h-32 bg-linear-to-b from-transparent to-canvas"
      >
      </div>
    </div>
  </section>

  <!-- ──────────────────── Recent posts ──────────────────── -->
  {
    posts.length > 0 && (
      <section class="container-page pb-section">
        <div class="flex items-end justify-between gap-4">
          <h2 class="display-lg">최근 글</h2>
          <a
            href="/blog"
            class="text-[0.9375rem] font-medium text-primary transition-colors hover:text-primary-active"
          >
            모든 글 보기 →
          </a>
        </div>

        <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {posts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="group flex h-full flex-col rounded-lg border border-hairline bg-surface-card p-5 transition-colors hover:border-hairline-strong"
            >
              <div class="caption-uppercase font-jetbrains flex flex-wrap items-center gap-x-2 text-muted">
                <span>{fmt(post.data.date)}</span>
                {post.data.tags[0] && (
                  <>
                    <span class="text-muted-soft">·</span>
                    <span class="text-primary">{post.data.tags[0]}</span>
                  </>
                )}
              </div>
              <h3 class="title-sm mt-3 line-clamp-2 transition-colors group-hover:text-primary">
                {post.data.title}
              </h3>
              <p class="body-sm mt-2 line-clamp-3 text-body">{post.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )
  }

  <!-- ──────────────── Closing band — skills fade-in + contact ──────────────── -->
  <section class="border-t border-hairline">
    <div class="container-page py-24 text-center md:py-32">
      <!-- Oversized skill stack: each line steps up in opacity, fading from
           near-invisible at the top to solid ink on the closing line. -->
      <div class="mx-auto flex max-w-4xl flex-col items-center">
        {
          skills.map((s, i) => (
            <span
              class="skill-line font-semibold tracking-tight text-ink"
              style={`opacity: ${(0.55 + (0.45 * i) / (skills.length - 1)).toFixed(3)}`}
            >
              {s}
            </span>
          ))
        }
      </div>

      <div class="mt-12 flex flex-wrap items-center justify-center gap-3 md:mt-16">
        <a
          href={`mailto:${contactEmail}`}
          class="inline-flex h-12 items-center gap-2 rounded-full bg-ink px-8 text-[0.9375rem] font-medium text-canvas transition-opacity hover:opacity-90"
        >
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect
              x="3"
              y="5"
              width="18"
              height="14"
              rx="2"
              stroke="currentColor"
              stroke-width="1.8"></rect>
            <path
              d="m4 7 8 6 8-6"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
          이메일 보내기
        </a>
        <a
          href={linkedInUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-12 items-center gap-2 rounded-full border border-hairline-strong bg-surface-card px-8 text-[0.9375rem] font-medium text-ink transition-colors hover:border-ink"
        >
          <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14ZM7.12 20.45H3.55V9h3.57v11.45ZM22.22 0H1.77C.8 0 0 .78 0 1.74v20.52C0 23.22.8 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.74V1.74C24 .78 23.2 0 22.22 0Z"></path>
          </svg>
          LinkedIn
        </a>
      </div>
    </div>
  </section>

  <!-- Hero editor: clicking a file swaps the visible markdown pane. -->
  <style>
    /* Dotted backdrop behind hero + IDE mockup, masked to fade out near the
       bottom so it dissolves into the page. */
    .hero-dots::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: -1;
      pointer-events: none;
      color: var(--color-ink);
      background-image: radial-gradient(circle at 1px 1px, currentColor 1px, transparent 0);
      background-size: 15px 15px;
      background-position: 7.5px 7.5px;
      opacity: 0.08;
      -webkit-mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
      mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
    }

    /* Blinking caret shown at the end of the body while it types in. */
    [data-typing-body].is-typing::after {
      content: "";
      display: inline-block;
      width: 0.5em;
      height: 1.05em;
      margin-left: 1px;
      transform: translateY(0.18em);
      background-color: var(--color-primary);
      animation: hero-caret-blink 1s steps(1) infinite;
    }
    @keyframes hero-caret-blink {
      0%,
      50% {
        opacity: 1;
      }
      50.01%,
      100% {
        opacity: 0;
      }
    }
    @media (prefers-reduced-motion: reduce) {
      [data-typing-body].is-typing::after {
        animation: none;
      }
    }

    [data-file-btn][data-active] {
      background-color: var(--color-surface-strong);
      color: var(--color-ink);
    }

    /* Oversized fade-in skill stack (closing band). */
    .skill-line {
      display: block;
      font-size: clamp(2.75rem, 9vw + 1rem, 6.5rem);
      line-height: 1.02;
      letter-spacing: -0.04em;
    }
  </style>
  <script is:inline>
    (() => {
      const root = document.getElementById("hero-editor");
      if (!root) return;
      const btns = root.querySelectorAll("[data-file-btn]");
      const panes = root.querySelectorAll("[data-file-pane]");
      const chrome = root.querySelector("[data-file-name]");

      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      // ── Typewriter for the editor body ────────────────────────────
      // Reveal the body HTML grapheme-by-grapheme while preserving the syntax-
      // highlight tags: snapshot every text node's full text once, then on each
      // tick truncate the live text nodes to the first N characters.
      const infoFor = (pane) => {
        const body = pane.querySelector("[data-typing-body]");
        if (!body) return null;
        if (body.__typing) return body.__typing;
        const nodes = [];
        const walker = document.createTreeWalker(body, NodeFilter.SHOW_TEXT);
        let n;
        while ((n = walker.nextNode())) nodes.push({ node: n, text: n.textContent });
        const fullText = nodes.map((it) => it.text).join("");
        const info = { body, nodes, total: fullText.length, fullText, timer: null };
        body.__typing = info;
        return info;
      };

      const reveal = (info, count) => {
        let remaining = count;
        for (const { node, text } of info.nodes) {
          if (remaining >= text.length) {
            if (node.textContent !== text) node.textContent = text;
            remaining -= text.length;
          } else {
            node.textContent = text.slice(0, Math.max(0, remaining));
            remaining = 0;
          }
        }
      };

      const play = (pane) => {
        const info = infoFor(pane);
        if (!info) return;
        clearTimeout(info.timer);
        if (reduceMotion || info.total === 0) {
          reveal(info, info.total);
          info.body.classList.remove("is-typing");
          return;
        }
        // One character per tick with a human-ish cadence: a base keystroke
        // interval plus jitter, longer pauses after line breaks and at the end
        // of sentences/clauses.
        const BASE = 22; // ms per keystroke
        const delayFor = (ch) => {
          if (ch === "\n") return 200 + Math.random() * 120;
          if (".!?。".includes(ch)) return 260 + Math.random() * 140;
          if (",;:·)".includes(ch)) return 120 + Math.random() * 80;
          if (ch === " ") return BASE + 30 + Math.random() * 40;
          return BASE + Math.random() * 45;
        };

        let count = 0;
        info.body.classList.add("is-typing");
        reveal(info, 0);
        const step = () => {
          count += 1;
          reveal(info, count);
          if (count < info.total) {
            const ch = info.fullText[count - 1] ?? "";
            info.timer = setTimeout(step, delayFor(ch));
          } else {
            info.body.classList.remove("is-typing");
          }
        };
        info.timer = setTimeout(step, 280);
      };

      btns.forEach((btn) => {
        btn.addEventListener("click", () => {
          const id = btn.getAttribute("data-file-btn");
          btns.forEach((b) => b.toggleAttribute("data-active", b === btn));
          panes.forEach((p) => {
            const active = p.getAttribute("data-file-pane") === id;
            p.hidden = !active;
            if (active) play(p);
          });
          if (chrome) chrome.textContent = "단로그 — " + btn.getAttribute("data-file-name");
        });
      });

      // Type the initially-active pane once the editor scrolls into view.
      const firstPane = panes[0];
      if (firstPane) {
        if ("IntersectionObserver" in window) {
          const io = new IntersectionObserver(
            (entries, obs) => {
              if (entries.some((e) => e.isIntersecting)) {
                obs.disconnect();
                play(firstPane);
              }
            },
            { threshold: 0.25 },
          );
          io.observe(root);
        } else {
          play(firstPane);
        }
      }
    })();
  </script>
</Layout>
