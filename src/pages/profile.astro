---
import Layout from "../layouts/Layout.astro";
import { contactEmail, education, experiences, linkedInUrl, profile } from "@shared/constants";
---

<Layout title="프로필" description={`${profile.name} · ${profile.role}`}>
  <!-- ───────────────────────── Intro ───────────────────────── -->
  <section class="container-page pt-section pb-16 md:pb-20">
    <span class="caption-uppercase text-muted">Profile</span>
    <h1 class="display-mega mt-4">{profile.name}</h1>
    <p class="display-sm mt-2 text-muted">{profile.role}</p>
    <p class="body-md mt-7 max-w-2xl text-balance text-body">{profile.intro}</p>

    <div class="mt-9 flex flex-wrap items-center gap-3">
      <a
        href={profile.githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex h-11 items-center gap-2 rounded-full bg-ink px-6 text-[0.9375rem] font-medium text-canvas transition-opacity hover:opacity-90"
      >
        <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.54-3.88-1.54-.52-1.33-1.28-1.68-1.28-1.68-1.05-.71.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.83 1.19 3.09 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.56A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"
          ></path>
        </svg>
        GitHub
      </a>
      <a
        href={`mailto:${contactEmail}`}
        class="inline-flex h-11 items-center gap-2 rounded-full border border-hairline-strong bg-surface-card px-6 text-[0.9375rem] font-medium text-ink transition-colors hover:border-ink"
      >
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.8"></rect>
          <path d="m4 7 8 6 8-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        이메일
      </a>
      <a
        href={linkedInUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex h-11 items-center gap-2 rounded-full border border-hairline-strong bg-surface-card px-6 text-[0.9375rem] font-medium text-ink transition-colors hover:border-ink"
      >
        <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14ZM7.12 20.45H3.55V9h3.57v11.45ZM22.22 0H1.77C.8 0 0 .78 0 1.74v20.52C0 23.22.8 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.74V1.74C24 .78 23.2 0 22.22 0Z"
          ></path>
        </svg>
        LinkedIn
      </a>
    </div>
  </section>

  <!-- ───────────────────────── Experience ───────────────────────── -->
  <section class="container-page pb-section">
    <h2 class="display-lg">경력</h2>

    <div class="mt-10 space-y-16">
      {
        experiences.map((exp) => (
          <div>
            {/* Company header */}
            <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1 border-b border-hairline pb-4">
              <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                <h3 class="title-md">{exp.company}</h3>
                <span class="body-sm text-muted">{exp.role}</span>
              </div>
              <span class="code-type text-muted-soft">{exp.period}</span>
            </div>

            {/* Projects */}
            <div class="mt-6 space-y-4">
              {exp.projects.map((project) => (
                <article class="rounded-lg border border-hairline bg-surface-card p-6 md:p-7">
                  <h4 class="title-sm">{project.name}</h4>
                  <p class="body-sm mt-1.5 text-muted">{project.summary}</p>

                  <ul class="mt-5 space-y-3.5">
                    {project.highlights.map((h) => (
                      <li class="flex gap-3">
                        <span class="mt-[0.5rem] h-1.5 w-1.5 shrink-0 rounded-full bg-primary" />
                        <div>
                          <p class="body-sm font-medium text-body-strong">{h.title}</p>
                          {h.detail && <p class="body-sm mt-1 text-body">{h.detail}</p>}
                        </div>
                      </li>
                    ))}
                  </ul>

                  {project.tech && (
                    <div class="mt-5 flex flex-wrap gap-1.5">
                      {project.tech.map((t) => (
                        <span class="code-type rounded-md border border-hairline bg-canvas-soft px-2 py-0.5 text-muted">
                          {t}
                        </span>
                      ))}
                    </div>
                  )}
                </article>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ───────────────────────── Education ───────────────────────── -->
  <section class="container-page pb-section">
    <h2 class="display-lg">교육</h2>
    <div class="mt-8 max-w-3xl space-y-4">
      {
        education.map((e) => (
          <article class="rounded-lg border border-hairline bg-surface-card p-6">
            <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
              <h3 class="title-sm">{e.name}</h3>
              <span class="code-type text-muted-soft">{e.period}</span>
            </div>
            <p class="body-sm mt-3 text-body">{e.detail}</p>
          </article>
        ))
      }
    </div>
  </section>
</Layout>
