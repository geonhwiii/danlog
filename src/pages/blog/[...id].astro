---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  // Sorted newest → oldest so each post knows its chronological neighbours.
  const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  );
  const n = posts.length;
  return posts.map((post, i) => ({
    params: { id: post.id },
    props: {
      post,
      // 다음 글 = 더 최신 글, 이전 글 = 더 오래된 글.
      // 끝에서는 순환(wrap-around)하여 항상 양쪽이 채워지도록 한다.
      // 글이 1개뿐이면 자기 자신을 가리키지 않도록 null.
      newer: n > 1 ? posts[(i - 1 + n) % n] : null,
      older: n > 1 ? posts[(i + 1) % n] : null,
    },
  }));
}

const { post, newer, older } = Astro.props;
const { Content, headings } = await render(post);

// Table of contents — section headings only (h2/h3).
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);

const formattedDate = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
})
  .format(post.data.date)
  .toUpperCase();
---

<Layout title={post.data.title} description={post.data.description}>
  <article class="container-page pt-section pb-section">
    <div class="relative mx-auto max-w-[680px]">
      <!-- Header -->
      <header class="mb-10">
        <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
          {
            post.data.tags.map((tag, i) => (
              <>
                {i > 0 && <span class="caption-uppercase font-jetbrains text-muted-soft">·</span>}
                <span class="caption-uppercase font-jetbrains text-primary">{tag}</span>
              </>
            ))
          }
        </div>
        <h1 class="display-lg mt-5">{post.data.title}</h1>
        <p class="body-md mt-4 text-muted">{post.data.description}</p>
        <div class="caption font-jetbrains mt-5 flex items-center gap-2 text-muted">
          <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
        </div>
      </header>

      <!-- Body -->
      <div class="prose">
        <Content />
      </div>

      <!-- Prev / next navigation -->
      {
        (newer || older) && (
          <nav class="mt-16 border-t border-hairline pt-10" aria-label="이전 글과 다음 글">
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
              {older && (
                <a
                  href={`/blog/${older.id}`}
                  class="group flex flex-col gap-1 rounded-sm border border-hairline p-5 transition-colors hover:border-hairline-strong"
                >
                  <span class="caption-uppercase font-jetbrains text-muted-soft">← 이전 글</span>
                  <span class="title-sm mt-1 transition-colors group-hover:text-primary">{older.data.title}</span>
                </a>
              )}
              {newer && (
                <a
                  href={`/blog/${newer.id}`}
                  class="group flex flex-col gap-1 rounded-sm border border-hairline p-5 text-right transition-colors hover:border-hairline-strong"
                >
                  <span class="caption-uppercase font-jetbrains text-muted-soft">다음 글 →</span>
                  <span class="title-sm mt-1 transition-colors group-hover:text-primary">{newer.data.title}</span>
                </a>
              )}
            </div>

            <div class="mt-8 flex justify-start">
              <a href="/blog" class="text-[0.875rem] font-medium text-primary transition-opacity hover:opacity-70">
                더 많은 글 보기 →
              </a>
            </div>
          </nav>
        )
      }

      <!-- Table of contents (desktop only, to the right of the article) -->
      {
        toc.length > 0 && (
          <aside class="absolute top-0 bottom-0 left-full ml-8 hidden w-52 xl:block">
            <nav class="post-toc sticky top-28" aria-label="목차">
              <p class="caption-uppercase mb-3 text-muted-soft">목차</p>
              <ul class="border-l border-hairline">
                {toc.map((h) => (
                  <li>
                    <a
                      href={`#${h.slug}`}
                      data-toc-link={h.slug}
                      class:list={[
                        "post-toc__link -ml-px block border-l border-transparent py-1 text-[0.8125rem] leading-snug text-muted transition-colors hover:text-ink",
                        h.depth === 3 ? "pl-7" : "pl-4",
                      ]}
                    >
                      {h.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </aside>
        )
      }
    </div>
  </article>
</Layout>

<script>
  // Code-block copy buttons + TOC scroll-spy. Runs on initial load and after
  // every View Transition navigation (astro:page-load fires on both).
  function enhancePost() {
    const article = document.querySelector("article .prose");
    if (!article) return;

    // ── Copy buttons on each code block ────────────────────────────
    const clipboardIcon =
      '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="9" y="9" width="11" height="11" rx="2" stroke="currentColor" stroke-width="1.8"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>';
    const checkIcon =
      '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m20 6-11 11-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>';

    const figures = article.querySelectorAll<HTMLElement>(
      "figure[data-rehype-pretty-code-figure]",
    );
    figures.forEach((figure) => {
      if (figure.querySelector(".code-copy")) return; // already enhanced
      const pre = figure.querySelector("pre");
      const code = figure.querySelector("pre code");
      if (!pre || !code) return;

      // Reuse the title bar (title="…") as the header, or synthesize one from
      // the block's language so untitled blocks still get a clean header row.
      let header = figure.querySelector<HTMLElement>(
        "figcaption[data-rehype-pretty-code-title]",
      );
      if (!header) {
        const lang =
          pre.getAttribute("data-language") ||
          code.getAttribute("data-language") ||
          "text";
        header = document.createElement("div");
        header.className = "code-header";
        const label = document.createElement("span");
        label.className = "code-header__lang";
        label.textContent = lang;
        header.appendChild(label);
        figure.insertBefore(header, pre);
      }

      const btn = document.createElement("button");
      btn.type = "button";
      btn.className = "code-copy";
      btn.setAttribute("aria-label", "코드 복사");
      btn.innerHTML = `<span class="code-copy__icon">${clipboardIcon}</span><span class="code-copy__label">Copy</span>`;

      const copyText = async (text: string) => {
        try {
          await navigator.clipboard.writeText(text);
          return true;
        } catch {
          // Fallback for non-focused / older contexts.
          const ta = document.createElement("textarea");
          ta.value = text;
          ta.style.position = "fixed";
          ta.style.opacity = "0";
          document.body.appendChild(ta);
          ta.select();
          let ok = false;
          try {
            ok = document.execCommand("copy");
          } catch {
            ok = false;
          }
          ta.remove();
          return ok;
        }
      };

      let resetTimer: ReturnType<typeof setTimeout> | undefined;
      btn.addEventListener("click", async () => {
        const text = code.textContent ?? "";
        if (!(await copyText(text))) return;
        btn.classList.add("is-copied");
        btn.innerHTML = `<span class="code-copy__icon">${checkIcon}</span><span class="code-copy__label">Copied</span>`;
        clearTimeout(resetTimer);
        resetTimer = setTimeout(() => {
          btn.classList.remove("is-copied");
          btn.innerHTML = `<span class="code-copy__icon">${clipboardIcon}</span><span class="code-copy__label">Copy</span>`;
        }, 2000);
      });

      header.appendChild(btn);
    });

    // ── TOC scroll-spy ─────────────────────────────────────────────
    const links = Array.from(
      document.querySelectorAll<HTMLAnchorElement>("[data-toc-link]"),
    );
    if (links.length === 0) return;

    const linkBySlug = new Map(links.map((l) => [l.dataset.tocLink, l]));
    const targets = links
      .map((l) => document.getElementById(l.dataset.tocLink ?? ""))
      .filter((el): el is HTMLElement => el !== null);

    let active: HTMLAnchorElement | undefined;
    const setActive = (slug: string | undefined) => {
      if (!slug) return;
      const next = linkBySlug.get(slug);
      if (!next || next === active) return;
      active?.classList.remove("is-active");
      next.classList.add("is-active");
      active = next;
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (visible[0]) setActive(visible[0].target.id);
      },
      { rootMargin: "-80px 0px -70% 0px", threshold: 0 },
    );
    targets.forEach((t) => observer.observe(t));
  }

  document.addEventListener("astro:page-load", enhancePost);
</script>
